# ============================================
# 数据库
# ============================================
DATABASE_URL=postgresql://finsim:finsim_dev_password@localhost:5432/finsim
POSTGRES_PASSWORD=finsim_dev_password

# ============================================
# NextAuth.js 认证 (v5)
# ============================================
# next-auth v5 默认读 AUTH_SECRET；auth.config.ts 已 fallback 到 NEXTAUTH_SECRET 兼容 v4 老部署。
# 新部署建议设 AUTH_SECRET；两者都生效。
AUTH_SECRET=dev-secret-change-in-production-must-be-256-bits
NEXTAUTH_SECRET=dev-secret-change-in-production-must-be-256-bits
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ============================================
# 管理密钥
# ============================================
ADMIN_KEY=finsim-teacher-key

# ============================================
# Cron token（可选）
# ============================================
# /api/cron/release-submissions 自动公布扫描守护：
# - 设 CRON_TOKEN 后，部署 cron 必须传 x-cron-token header（生产建议）
# - 未设 CRON_TOKEN，admin 角色用户也可手动调该 endpoint（开发/小团队）
CRON_TOKEN=

# ============================================
# AI Provider（默认）
# ============================================
AI_PROVIDER=mimo
AI_FALLBACK_PROVIDER=deepseek

# ============================================
# 小米 MiMo（OpenAI-compatible）
# ============================================
MIMO_API_KEY=sk-xxx
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# ============================================
# 通义千问 / Qwen
# ============================================
QWEN_API_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 默认模型（当 feature-specific AI_*_MODEL 未设置时使用）
QWEN_MODEL=qwen3.5-plus

# ============================================
# DeepSeek
# ============================================
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# Gemini（可选，需代理）
# ============================================
GEMINI_API_KEY=
GEMINI_PROXY_URL=

# ============================================
# OpenAI 兼容（可选）
# ============================================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================
# 按 Feature 覆盖（Phase 4 spec 模型分配）
#
# 核心分层策略：
#   - 默认：MiMo v2.5 Pro，覆盖出题、模拟对话、批改与洞察。
#   - 如需按功能替换 provider/model，可设置对应 AI_*_PROVIDER / AI_*_MODEL。
#   - 高频功能可改用 mimo-v2.5 或 mimo-v2-flash；长上下文/高质量生成保留 mimo-v2.5-pro。
#   - 用户感知强 / 一次性 / 高价值 → mimo-v2.5-pro
#     · AI 批量出题（创建任务流程一次性）
#     · 模拟对话（学生沉浸式体验）
#     · Insights 聚合（教师看数据）
#   - 高频 / 在线批改 / 学伴追问 → mimo-v2.5
#     · 批改（评估）
#     · Study Buddy Socratic 引导
#   - 低置信度批改二次校验 → mimo-v2.5-pro（fallback model）
# ============================================

# 模拟对话：沉浸式多轮对话
AI_SIMULATION_PROVIDER=
AI_SIMULATION_MODEL=mimo-v2.5-pro

# 批改（evaluation 通用 + quizGrade + subjectiveGrade 继承）
AI_EVALUATION_PROVIDER=
AI_EVALUATION_MODEL=mimo-v2.5
# 低置信度复合校验（Phase 4+ 规划，当前 ai.service 仅读 FALLBACK_PROVIDER；MODEL 为后续启用预留）
AI_EVALUATION_FALLBACK_PROVIDER=
AI_EVALUATION_FALLBACK_MODEL=mimo-v2.5-pro

AI_QUIZ_GRADE_PROVIDER=
AI_QUIZ_GRADE_MODEL=mimo-v2.5
AI_SUBJECTIVE_GRADE_PROVIDER=
AI_SUBJECTIVE_GRADE_MODEL=mimo-v2.5

# AI 批量出题：创建任务流程中一次性用最强
AI_TASK_DRAFT_PROVIDER=
AI_TASK_DRAFT_MODEL=mimo-v2.5-pro

# Study Buddy Socratic：高频交互用均衡
AI_STUDY_BUDDY_PROVIDER=
AI_STUDY_BUDDY_MODEL=mimo-v2.5

AI_IMPORT_PROVIDER=
AI_IMPORT_MODEL=

# Insights 聚合（Phase 5 计划）：教师数据洞察用最强
AI_INSIGHTS_PROVIDER=
AI_INSIGHTS_MODEL=mimo-v2.5-pro

# Phase 8 B3 一周洞察（教师工作台一周洞察按钮）：长 context 用 MiMo
AI_WEEKLY_INSIGHT_PROVIDER=mimo
AI_WEEKLY_INSIGHT_MODEL=mimo-v2.5-pro

# ============================================
# 限流
# ============================================
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_WINDOW_MS=3600000
AI_RATE_LIMIT_MAX_PER_FEATURE=100

# ============================================
# 功能开关
# ============================================
ENABLE_AUDIT_LOGS=true
ENABLE_STUDY_BUDDY=true
# 生产环境默认关闭学生自助注册，只有明确开启才暴露公开班级列表与注册入口。
ENABLE_STUDENT_SELF_REGISTRATION=true

# ============================================
# 文件存储
# ============================================
FILE_STORAGE_TYPE=local
FILE_STORAGE_PATH=./public/uploads

# ============================================
# 服务配置
# ============================================
NODE_ENV=development
PORT=3000
